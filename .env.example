# AI Provider — "claude-cli" runs on your local Claude subscription (no API key).
AI_PROVIDER=claude-cli         # or "anthropic" / "openai"
CLAUDE_CLI_MODEL=sonnet        # "sonnet" (recommended) or "opus"
CLAUDE_CLI_PATH=claude         # absolute path to the claude binary if not on PATH

# ── Token / cost guardrails ──
# How often to CHECK sources for changes (minutes). 0 disables auto-refresh.
AUTO_REFRESH_MINUTES=60
# Auto-refresh only REGENERATES (a Claude call) when changed AND at least this many
# minutes since the last auto-gen AND under the daily cap AND inside work hours.
AUTO_MIN_GAP_MINUTES=90
AUTO_MAX_PER_DAY=8
# Pause length after a usage-limit hit when Claude didn't say when it resets.
CLAUDE_LIMIT_COOLDOWN_MINUTES=30

# OpenAI — only used for semantic-memory embeddings (not generation).
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Anthropic (optional — set AI_PROVIDER=anthropic to use)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Server
PORT=3001
VITE_API_URL=http://localhost:3001

# ── OAuth connectors (see CONNECTORS.md for the one-time setup) ──
# Where Google/Slack send users back after sign-in (must match the console)
OAUTH_REDIRECT_BASE=http://localhost:3001
# Where to return the user in the UI after connecting
APP_BASE=http://localhost:5173

# Google (Gmail + Calendar) — one app covers both
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Slack
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# Optional: n8n webhook secret for verifying incoming briefings
N8N_WEBHOOK_SECRET=your-secret-here
